# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Optional: Admin chat ID to receive form submissions
# Get your ID: https://t.me/userinfobot
# ADMIN_CHAT_ID=123456789

# Optional: Hotline phone number displayed to users
HOTLINE_PHONE=+7 (495) 123-45-67

# Optional: Phone shown when user declines consent
CONSENT_DECLINE_PHONE=+7 (495) 123-45-67
